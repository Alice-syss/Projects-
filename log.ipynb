import pandas as pd
import numpy as np

def run_logistics_pipeline():
    print("=== STARTING TECHNICAL PROGRAM: DATA INGESTION ===")
    
    try:
        csv_file = "(your path)"
        df = pd.read_csv(csv_file)
        print(f"✓ Ingestion Success: Loaded {len(df)} operational records.")
    except Exception as e:
        print(f"❌ Critical Failure: Data ingestion broken. Error: {str(e)}")
        return

    print("\n=== STARTING TRANSFORMATION LAYER ===")


    df['Shipment_Type'] = df['Shipment_Type'].astype(str).str.strip().str.upper()

    df['SLA_Status'] = df['On_Time'].apply(lambda x: 'MET' if x == 1 else 'BREACHED')

    median_weight = df['Weight_kg'].median()
    df['Weight_kg'] = df['Weight_kg'].fillna(median_weight).astype(float)

    df.columns = [col.upper() for col in df.columns]
    print("✓ Schema Alignment: Formatted all column headers to UPPERCASE to match Snowflake.")

    df.to_csv('snowflake_ready_data.csv', index=False)
    print("\n✓ Program Pipeline Complete: 'snowflake_ready_data.csv' exported successfully.")

if __name__ == "__main__":
    run_logistics_pipeline()
